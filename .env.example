# .env.example
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# ============================================================
# SUPABASE
# ============================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================================
# STRIPE (Frontend - Public Key)
# ============================================================
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ============================================================
# STRIPE (Backend - Secret Key - DO NOT SHARE!)
# ============================================================
VITE_STRIPE_SECRET_KEY=sk_test_your_secret_key

# ============================================================
# PAYMENT SERVER URL
# ============================================================
# Local development
VITE_PAYMENT_SERVER_URL=http://localhost:3001

# Production (uncomment when deploying)
# VITE_PAYMENT_SERVER_URL=https://your-payment-server.onrender.com